NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Sync script only (never expose in browser/frontend) ──────────────────────
# Used by scripts/sync-results.ts and the GitHub Actions workflow.
# In production: set these as GitHub Actions Secrets, not in .env files.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: football-data.org API key for live results (free tier).
# Leave blank to use mock data. See scripts/adapters/football-data.ts.
FOOTBALL_API_KEY=

# ── Email notifications (contact form → admin) ────────────────────────────────
# Required for email alerts when a user sends a message via /contact.
# If not set, messages are still saved to the database — no email is sent.
# See src/lib/email.ts for provider implementation (currently a TODO).
ADMIN_EMAIL=
EMAIL_FROM=VM 2026 <noreply@yourdomain.com>
EMAIL_PROVIDER_API_KEY=

# Optional: used to build the /admin/messages link in email notifications.
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
